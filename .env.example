# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/migrationsdb
DB_ECHO=false

# --- Server ---
HOST=127.0.0.1
PORT=8765
LOG_LEVEL=info

# --- Frontend (served by uvicorn in prod; dev server in development) ---
FRONTEND_DEV_URL=http://127.0.0.1:3001

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/google-service-account.json
SHEETS_SYNC_INTERVAL_MIN=15
