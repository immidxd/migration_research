# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.local
*.log

# Secrets / credentials
secrets/
*.json.key
*-credentials.json
service-account*.json

# Node / frontend
node_modules/
frontend/build/
frontend/.eslintcache

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Data — raw downloads kept out of git, only fixtures committed
data/basemaps/*
!data/basemaps/.gitkeep
!data/territories/.gitkeep
!data/fixtures/.gitkeep
# DB snapshot lives in the project folder for portability (copy the folder to
# carry your facts), but is kept OUT of git — it's a moving binary, not source.
data/fixtures/*.dump
# data/territories/raw/ IS tracked: it holds the academic source files
# (RiStat 1897 GeoPackages; CHGIS V6 1911 provinces; Natural Earth) so the
# project is reproducible from a clean clone. All are CC0 / public domain.

# Alembic local cache
backend/migrations/__pycache__/

# Build artefacts
dist/
build/
